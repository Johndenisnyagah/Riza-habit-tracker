# ========================================
# RIZA HABIT TRACKER - ENVIRONMENT VARIABLES
# ========================================
# This is a template file. Copy this to .env and fill in your actual values.

# ========================================
# FOR REVIEWING
# ========================================
# If you are a reviewer for this project:
#
# CREDENTIALS ARE PROVIDED IN THE PRESENTATION TITLE SLIDE
#
# Simply:
# 1. Copy the MongoDB connection string from the presentation
# 2. Copy the JWT secret from the presentation
# 3. Paste them into a new .env file (copy this template)
# 4. Run: npm install
# 5. Run: npm start
# 6. Open the app and login with the test user credentials from the presentation
#
# No need to create your own MongoDB account!
# All credentials are ready to use from the presentation.
#
# ========================================

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Atlas connection string (REQUIRED - Cloud Database)
# Copy from presentation title slide and paste below:
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# ========================================
# AUTHENTICATION
# ========================================
# JWT Secret Key for token signing (min 32 characters)
# Copy from presentation title slide and paste below:
JWT_SECRET=your-super-secret-random-key-here-make-it-long

# ========================================
# SERVER CONFIGURATION
# ========================================
# Port number for the backend server (optional - defaults to 5000 if not set)
PORT=5000

# Node environment (development/production)
NODE_ENV=development

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# Email verification uses these SMTP credentials.
# If not configured, verification links will be logged to the terminal (console fallback).
# This allows local testing without setting up SMTP.
#
# For production: Configure with real SMTP credentials (e.g., Gmail, SendGrid, Mailtrap)
# For local testing: Leave blank to use console logging
#
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM=noreply@riza.com

# Frontend URL for email verification links
# Used to generate verification links sent to users
FRONTEND_URL=http://localhost:8000

# ========================================
# SETUP INSTRUCTIONS (For Reviewers)
# ========================================
# 1. Copy this file and rename it to .env
# 2. Replace MONGO_URI with the connection string from the presentation
# 3. Replace JWT_SECRET with the secret from the presentation
# 4. Save the .env file
# 5. Run: npm install
# 6. Run: npm start
# 7. The backend should start on http://localhost:5000
# 8. Open index.html in your browser
# 9. Login with test user credentials from the presentation
# 10. For email verification testing: Check the backend terminal for verification links

# ========================================
# FOR DEVELOPERS (Creating Your Own Setup)
# ========================================
# If you want to create your own MongoDB database:
# 1. Sign up for a free MongoDB Atlas account at https://www.mongodb.com/cloud/atlas/register
# 2. Create a new cluster (free tier is sufficient)
# 3. Get your connection string and replace MONGO_URI above
# 4. Generate a JWT secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 5. Replace JWT_SECRET with your generated secret
# 6. (Optional) Configure SMTP for email sending:
#    - Sign up for a free account at https://mailtrap.io
#    - Get your SMTP credentials and update EMAIL_HOST, EMAIL_USER, EMAIL_PASS
#    - Or configure with your email provider (Gmail, SendGrid, etc.)
# 7. Update FRONTEND_URL if running frontend on a different port/URL
# 8. Follow steps 4-10 from "SETUP INSTRUCTIONS" above
